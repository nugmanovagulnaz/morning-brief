# Anthropic — claude.js
ANTHROPIC_API_KEY=sk-ant-...

# Telegram — telegram.js
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=-100...

# Google Calendar — calendar.js
# Service account credentials (from the downloaded JSON key file)
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Paste the private key value here; literal \n is fine — the code converts it
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your.email@gmail.com

# Security — morning-brief.js
# Any random secret; Vercel sends it as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-random-secret-here
